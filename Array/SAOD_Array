int main()
{
    system("chcp 65001 > nul"); //подключение русского языка 
	setlocale(LC_ALL, "RUSSIAN");
    // Генерирует случайное число, используя текущею дату, для непредсказуемости результата
    srand(time(0));
	size_t Asize = 100;
	double el = -123.0; // его там точно не существует
