	vector<double> arr; // описываем массив как вектор
	arr.resize(Asize); // даем ему размерность n из переданного аргумента argv[1]

	Vvod_array(arr); // выполняем ввод массива
	Screen_array(arr); // выводим на экран массив введеных коэффициентов
	cout << "\n";

	// выполняем запись массива в файл
	try { WriteFile(fileName, arr);	}  
	catch (const invalid_argument& error) {
		cout << error.what();
	}
	cout << "\n";

	// читаем из файла массив и выдаем на консоль
	try   // проверка на исключения
	{
		// Находим количество элементов массива из файла
		unsigned size_1 = SizeFile(fileName);
	}
	catch (const exception& error) // файл не открыт или пуст
	{
		// Код, который выполняется при возникновении исключения типа
		// Exception генерируется в блоке try
		cout << error.what() << endl; // Завершить
	}
	vector<double> arr1;
	arr1.resize(Asize); // Задаем размер size
	try {
		arr1 = ReadFile(fileName, Asize);
	} // ************ Try
	catch (const invalid_argument& error) {
		cout << error.what();
	}
	Screen_array(arr1); // выводим на экран массив введеных коэффициентов
	arr1.clear();

	arr.clear();
	return 0;
}

